<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title + ' | Talba Store' : 'Talba Store — كل ما تحتاجه في مكان واحد' %></title>
    <meta name="description" content="<%= typeof description !== 'undefined' ? description : 'منتجات مختارة بعناية للحياة اليومية. توصيل لكل مصر والدفع عند الاستلام.' %>">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;900&family=Outfit:wght@300;600;800&display=swap" rel="stylesheet">
    
    <!-- CSS -->
    <link rel="stylesheet" href="/css/main.css">
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="apple-touch-icon" href="/favicon.svg">

</head>
<body>
    <%- include('../partials/header') %>

    <main>
        <%- body %>
    </main>

    <%- include('../partials/footer') %>

    <!-- Global Scripts -->
    <script src="/js/cart.js"></script>
    <script>
        // Update cart badge on load
        document.addEventListener('DOMContentLoaded', () => {
            if (window.updateCartBadge) window.updateCartBadge();
        });
    </script>
</body>
</html>
