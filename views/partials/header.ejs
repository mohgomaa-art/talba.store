<header class="main-header">
    <div class="container">
        <div class="header-top">
            <a href="/" class="logo-wrap" style="display: flex; align-items: center; gap: 12px; flex-direction: row;">
                <svg class="logo-svg" style="width: 42px; height: auto; display: block;" viewBox="0 0 108 130" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12,22 Q12,10 24,10 L84,10 Q96,10 96,22 L96,86 L54,120 L12,86 Z" fill="#27ae60"/>
                    <circle cx="54" cy="24" r="7" fill="white" opacity="0.9"/>
                    <circle cx="54" cy="24" r="4" fill="#27ae60"/>
                    <rect x="22" y="48" width="64" height="14" rx="5" fill="white"/>
                    <rect x="43" y="48" width="22" height="44" rx="5" fill="white"/>
                </svg>
                <div style="display: flex; flex-direction: column; line-height: 1;">
                    <div class="wordmark-main" style="margin: 0; padding: 0;">Tal<span class="wordmark-accent">ba</span></div>
                    <div class="wordmark-sub" style="margin-top: 2px;">STORE</div>
                </div>
            </a>

            
            <nav class="nav-categories">
                <ul>
                    <li><a href="/shop">الكل</a></li>
                    <li><a href="/shop?category=المطبخ">المطبخ</a></li>
                    <li><a href="/shop?category=المكياج والعناية">المكياج</a></li>
                    <li><a href="/shop?category=الاكسسوارات">الاكسسوارات</a></li>
                    <li><a href="/shop?category=الديكور">الديكور</a></li>
                    <li><a href="/shop?category=الإلكترونيات">الإلكترونيات</a></li>
                </ul>
            </nav>

            <div class="header-actions">
                <form action="/shop" method="GET" class="search-form">
                    <input type="text" name="search" id="headerSearch" placeholder="بحث...">
                    <button type="submit">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    </button>
                </form>
                
                <a href="/cart" class="cart-btn">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                    <span id="cart-badge" class="badge">0</span>
                </a>
            </div>
        </div>
    </div>
</header>

<div class="trust-bar">
    <div class="container">
        <div class="trust-flex">
            <span class="trust-item">توصيل لكل مصر</span>
            <span class="trust-item">الدفع عند الاستلام</span>
            <span class="trust-item">استرجاع مضمون</span>
            <span class="trust-item">شحن سريع</span>
        </div>
    </div>
</div>
