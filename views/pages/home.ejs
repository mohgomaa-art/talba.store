<section class="hero">
    <div class="hero-content">
        <h1>اللي بتدور عليه، لقيّته هنا.</h1>
        <p>منتجات مختارة بعناية للحياة اليومية.</p>
        <a href="/shop" class="btn btn-primary">تسوق الآن</a>
    </div>
</section>

<section class="categories-grid container">
    <h2 class="section-title">الأقسام</h2>
    <div class="grid">
        <a href="/shop?category=المطبخ" class="category-card" style="--accent: #E63946;">
            <div class="card-bg" style="background-image: url('https://images.unsplash.com/photo-1556910103-1c02745aae4d?auto=format&fit=crop&q=80&w=600');"></div>
            <div class="card-content">
                <h3>المطبخ</h3>
                <span>عرض المنتجات</span>
            </div>
        </a>
        
        <a href="/shop?category=المكياج والعناية" class="category-card" style="--accent: #1A1A1A;">
            <div class="card-bg" style="background-image: url('https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?auto=format&fit=crop&q=80&w=600');"></div>
            <div class="card-content">
                <h3>المكياج والعناية</h3>
                <span>عرض المنتجات</span>
            </div>
        </a>

        <a href="/shop?category=الاكسسوارات" class="category-card" style="--accent: #E63946;">
            <div class="card-bg" style="background-image: url('https://images.unsplash.com/photo-1616348436168-de43ad0db179?auto=format&fit=crop&q=80&w=600');"></div>
            <div class="card-content">
                <h3>الاكسسوارات</h3>
                <span>عرض المنتجات</span>
            </div>
        </a>
    </div>
</section>

<% if (featuredProducts && featuredProducts.length > 0) { %>
<section class="featured-products container">
    <h2 class="section-title">الأكثر مبيعاً</h2>
    <div class="product-grid">
        <% featuredProducts.forEach(product => { %>
            <%- include('../partials/productCard', { product }) %>
        <% }) %>
    </div>
</section>
<% } %>

<section class="cta-search">
    <div class="container">
        <h2>مش لاقي حاجة؟ ابحث وهنجيبهالك</h2>
        <form action="/shop" method="GET" class="big-search">
            <input type="text" name="search" placeholder="ابحث عن منتج...">
            <button type="submit">بحث</button>
        </form>
    </div>
</section>
