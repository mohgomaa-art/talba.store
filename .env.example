# Taager API
TAAGER_API_KEY=
TAAGER_API_BASE=https://merchant.api.taager.com
TAAGER_PHONE=your_taager_phone
TAAGER_PASS=your_taager_password

# Admin Credentials
ADMIN_USER=admin
ADMIN_PASS=your_secure_password
SESSION_SECRET=your_random_secret_key

# MongoDB Atlas - Get from https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/talba-store?retryWrites=true&w=majority

# Cloudinary - Get from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Server
PORT=3000
